{
  "name": "kach-weddings-timeline",
  "version": "1.1.0",
  "description": "Tidslinje-generator for bryllupsfotografering · KACH Weddings",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit -p jsconfig.json",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node scripts/migrate.js",
    "test-account": "node scripts/set-test-account.js"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@sentry/vite-plugin": "^3.6.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.13.0",
    "globals": "^15.11.0",
    "jsdom": "^25.0.1",
    "pg": "^8.21.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "vite": "^5.4.0",
    "vitest": "^2.1.4"
  },
  "dependencies": {
    "@clerk/backend": "^3.7.0",
    "@clerk/clerk-js": "^6.16.1",
    "@neondatabase/serverless": "^1.1.0",
    "@sentry/browser": "^8.55.2",
    "@sentry/node": "^8.55.2",
    "drizzle-orm": "^0.45.2",
    "qrcode": "^1.5.4"
  }
}
