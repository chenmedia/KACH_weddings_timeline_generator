{
  "name": "kach-weddings-timeline",
  "version": "1.1.0",
  "description": "Tidslinje-generator for bryllupsfotografering · KACH Weddings",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit -p jsconfig.json",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node scripts/migrate.js",
    "test-account": "node scripts/set-test-account.js"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@sentry/vite-plugin": "^5.4.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "pg": "^8.22.0",
    "prettier": "^3.9.5",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@clerk/backend": "^3.11.4",
    "@clerk/clerk-js": "^6.25.2",
    "@neondatabase/serverless": "^1.1.0",
    "@sentry/browser": "^10.65.0",
    "@sentry/node": "^10.65.0",
    "drizzle-orm": "^0.45.2",
    "qrcode": "^1.5.4"
  }
}
