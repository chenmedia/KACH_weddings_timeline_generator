{
  "name": "kach-weddings-timeline",
  "version": "1.1.0",
  "description": "Tidslinje-generator for bryllupsfotografering · KACH Weddings",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --max-warnings 0",
