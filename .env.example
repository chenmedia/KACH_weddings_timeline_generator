# Optional: privacy-friendly, cookieless analytics (Plausible).
# Leave unset to disable analytics entirely (default).
# Set in Vercel → Project → Settings → Environment Variables.

# NOTE: the default Content-Security-Policy in vercel.json blocks external scripts.
# To use Plausible, also add https://plausible.io (or your self-hosted origin) to
# BOTH script-src and connect-src in vercel.json, or the script will be blocked.

# Your site's domain as registered in Plausible, e.g. tidslinje.kachweddings.no
VITE_PLAUSIBLE_DOMAIN=

# Optional: self-hosted Plausible script URL (defaults to plausible.io).
# VITE_PLAUSIBLE_SRC=https://plausible.io/js/script.js

# Optional: Subresource Integrity hash for the Plausible script (sha384-...).
# When set, the script is loaded with integrity + crossorigin for tamper protection.
# VITE_PLAUSIBLE_SRI=
