# Optional: privacy-friendly, cookieless analytics (Plausible).
# Leave unset to disable analytics entirely (default).
# Set in Vercel → Project → Settings → Environment Variables.

# NOTE: the default Content-Security-Policy in vercel.json blocks external scripts.
# To use Plausible, also add https://plausible.io (or your self-hosted origin) to
# BOTH script-src and connect-src in vercel.json, or the script will be blocked.

# Your site's domain as registered in Plausible, e.g. tidslinje.kachweddings.no
VITE_PLAUSIBLE_DOMAIN=

# Optional: self-hosted Plausible script URL (defaults to plausible.io).
# VITE_PLAUSIBLE_SRC=https://plausible.io/js/script.js

# Optional: Subresource Integrity hash for the Plausible script (sha384-...).
# When set, the script is loaded with integrity + crossorigin for tamper protection.
# VITE_PLAUSIBLE_SRI=

# =====================================================================
# Backend (Phase 1 — persistence + auth). All SERVER-ONLY unless prefixed
# with VITE_. The app runs client-only (localStorage) until these are set.
# =====================================================================

# Neon Postgres (EU region) connection string. SERVER-ONLY.
DATABASE_URL=

# Clerk auth. The secret key is SERVER-ONLY; the publishable key is the only
# value safe to expose to the browser (hence the VITE_ prefix).
CLERK_SECRET_KEY=
VITE_CLERK_PUBLISHABLE_KEY=

# Shared secret guarding the /api/cron/* endpoints (Vercel Cron sends it). SERVER-ONLY.
CRON_SECRET=

# Storage hygiene knobs (used by /api/cron/*). SERVER-ONLY.
RETENTION_MONTHS=36
STORAGE_ALERT_GB=1

# --- Later phases (leave blank for Phase 1) ---
# Encryption key for OAuth tokens at rest (32-byte base64). SERVER-ONLY.
# TOKEN_ENC_KEY=
# Google OAuth (Calendar + Gmail). SERVER-ONLY.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=
# HubSpot private-app token. SERVER-ONLY.
# HUBSPOT_TOKEN=
